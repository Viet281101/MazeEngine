{
  "name": "maze-engine-workspace",
  "private": true,
  "scripts": {
    "dev": "npm run supabase:start && npm run dev:frontend",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:docker": "docker compose up frontend",
    "supabase:init": "cd backend && supabase init",
    "supabase:start": "cd backend && supabase start",
    "supabase:stop": "cd backend && supabase stop",
    "supabase:status": "cd backend && supabase status",
    "supabase:reset": "cd backend && supabase db reset",
    "build": "npm --prefix frontend run build",
    "test": "npm --prefix frontend run test",
    "preview": "npm --prefix frontend run preview",
    "deploy": "npm --prefix frontend run deploy",
    "format": "npm --prefix frontend run format",
    "check:multilayer": "npm --prefix frontend run check:multilayer",
    "lint:file-names": "npm --prefix frontend run lint:file-names",
    "lint:eslint": "npm --prefix frontend run lint:eslint",
    "lint": "npm --prefix frontend run lint"
  },
  "devDependencies": {
    "supabase": "^2.84.4"
  }
}
